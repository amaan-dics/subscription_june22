                                                       t-att-value="plan.product_id.id"/>

                                                <input type="hidden" name="add_qty" value="1"/>

                                                <button type="submit" class="btn btn-gold-border w-100">

                                                    <t t-if="float(plan.price) &gt; current_amount">
                                                        Upgrade Plan
                                                    </t>

                                                    <t t-elif="float(plan.price) &lt; current_amount">
                                                        Downgrade Plan
                                                    </t>

                                                    <t t-else="">
                                                        Subscribe
                                                    </t>

                                                </button>
                                            </form>
                                        </t>
