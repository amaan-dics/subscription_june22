<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="find_match_template" name="Find Match Page"
              inherit_id="subscription_package_extended.find_match_template">
        <xpath expr="//div[hasclass('container') and hasclass('mt-4')]" position="replace">
            <section class="match-page">
                <div class="match-wrap">
                    <div class="match-head">
                        <div>
                            <div class="match-eyebrow">DISCOVER MEMBERS</div>
                            <h1>Find Your Match</h1>
                        </div>
                    </div>
                    <div class="match-filters">
                        <div class="custom-filter">
                            <button type="button" class="filter-btn">
                                <t t-esc="selected_location or 'All Locations'"/>
                                <i class="fa fa-chevron-down"/>
                            </button>
                            <div class="filter-menu">
                                <a t-att-href="'/match%s' % (
                selected_age and '?age=%s' % selected_age or ''
            )">
                                    All Locations
                                </a>

                                <t t-foreach="locations" t-as="loc">
                                    <a t-att-href="'/match?location=%s%s' % (
                    loc,
                    selected_age and '&amp;age=%s' % selected_age or ''
                )">
                                        <t t-esc="loc"/>
                                    </a>
                                </t>
                            </div>
                        </div>
                        <div class="custom-filter">
                            <button type="button" class="filter-btn">
                                <t t-if="selected_age == '18-25'">
                                    18 - 25
                                </t>
                                <t t-elif="selected_age == '26-35'">
                                    26 - 35
                                </t>
                                <t t-elif="selected_age == '36-50'">
                                    36 - 50
                                </t>
                                <t t-else="">
                                    Any Age
                                </t>

                                <i class="fa fa-chevron-down"/>

                            </button>

                            <div class="filter-menu">

                                <a t-att-href="'/match%s' % (
                selected_location and '?location=%s' % selected_location or ''
            )">
                                    Any Age
                                </a>

                                <a t-att-href="'/match?age=18-25%s' % (
                selected_location and '&amp;location=%s' % selected_location or ''
            )">
                                    18 - 25
                                </a>

                                <a t-att-href="'/match?age=26-35%s' % (
                selected_location and '&amp;location=%s' % selected_location or ''
            )">
                                    26 - 35
                                </a>

                                <a t-att-href="'/match?age=36-50%s' % (
                selected_location and '&amp;location=%s' % selected_location or ''
            )">
                                    36 - 50
                                </a>

                            </div>

                        </div>

                    </div>
                    <t t-if="not current_user.subscription_plan_id or current_user.subscription_plan_id.renewal_period not in ['weeks', 'months', 'years']">
                        <div class="premium-bar">
                            <div class="premium-left">
                                <div class="premium-icon">📍</div>
                                <div>
                                    <div class="premium-title">
                                        Nearby Members Filter
                                    </div>
                                    <div class="premium-sub">
                                        Find members within your chosen radius
                                    </div>
                                </div>
                            </div>
                            <div class="premium-badge">
                                🔒 SILVER+ FEATURE
                            </div>
                        </div>
                    </t>
                    <div class="match-grid">
                        <t t-foreach="users" t-as="user">
                            <t t-set="plan" t-value="current_user.subscription_plan_id"/>
                            <t t-set="connection_limit_reached"
                               t-value="(current_user.connection_used/2) &gt;= plan.connection_limit"/>
                            <t t-set="chat_limit_reached"
                               t-value="(current_user.chat_used/2) &gt;= plan.chat_limit"/>
                            <t t-set="req" t-value="request.env['connect.request'].sudo().search(['|',
                           '&amp;', ('from_user_id','=',current_user.id), ('to_user_id','=',user.id),
                           '&amp;', ('from_user_id','=',user.id), ('to_user_id','=',current_user.id)], limit=1)"/>
                            <div class="match-card">
                                <div class="online-dot"/>
                                <div class="avatar-wrap">
                                    <img t-att-src="'/partner/avatar/%s/image_1920' % user.id"
                                         class="member-avatar"/>
                                </div>
                                <div class="match-body">
                                    <h4>
                                        <t t-esc="user.name"/>
                                    </h4>
                                    <div class="member-meta">
                                        <t t-if="user.age">
                                            <span>
                                                <t t-esc="user.age"/>
                                                Years
                                            </span>
                                        </t>
                                    </div>
                                    <div class="member-bio">
                                        Demo profile introduction text goes here.
                                    </div>
                                    <div class="match-actions">
                                        <t t-if="user.kyc_status == 'approved'">
                                            <t t-if="connection_limit_reached">
                                                <div class="limit-box">
                                                    Connection Limit Reached
                                                </div>
                                            </t>
                                            <t t-elif="not req">
                                                <a t-att-href="'/send_request/%s' % user.id"
                                                   class="match-btn gold-btn"
                                                   t-if="not connection_limit_reached">
                                                    Connect
                                                </a>
                                            </t>
                                            <t t-elif="req.state == 'pending'">
                                                <div class="pending-box">
                                                    Request Sent
                                                </div>
                                            </t>
                                            <t t-elif="req.state == 'accepted'">
                                                <a t-att-href="'/chatbox?user_id=%s' % user.id"
                                                   class="match-btn dark-btn"
                                                   t-if="not chat_limit_reached">
                                                    Chat Now
                                                </a>
                                                <div class="limit-box" t-if="chat_limit_reached">
                                                    Chats Limit Reached
                                                </div>
                                            </t>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>
        </xpath>
    </template>
</odoo>