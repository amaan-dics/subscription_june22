<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="user_profile_template" name="User Profile">
        <t t-call="website.layout">
            <div class="profile-page connect" style="min-height: 100vh; background: #0b110c;">
                <div class="container"
                     style="max-width: 1000px; margin: 0 auto; padding-top: 40px; padding-bottom: 80px;">
                    <!--  Header  -->
                    <div class="mb-5">
                        <h2 class="st lt" style="font-size: 2rem; color: #fff; margin-bottom: 0.3rem;">My Profile</h2>
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem;">Manage your account details and
                            subscription information.
                        </p>
                    </div>
                    <!--  Auto-dismissing Success Message  -->
                    <t t-if="success">
                        <div id="profile_success_alert"
                             class="alert mt-3 mb-4 alert-dismissible fade show d-flex justify-content-between align-items-center"
                             style="background: rgba(46, 196, 113, 0.1); border: 1px solid rgba(46, 196, 113, 0.5); color: #4ade80;">
                            <div>
                                <i class="fa fa-check-circle me-2"/>
                                Profile updated successfully!
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"
                                    style="filter: invert(1) grayscale(100%) brightness(200%); background: transparent; border: none; font-size: 1.2rem; color: #4ade80; cursor: pointer;">
                            </button>
                        </div>
                        <script>setTimeout(function() { var alertNode =
                            document.getElementById('profile_success_alert'); if (alertNode) {
                            alertNode.style.transition = 'opacity 0.5s ease'; alertNode.style.opacity = '0';
                            setTimeout(function() { alertNode.remove(); }, 500); } }, 3000);
                        </script>
                    </t>
                    <div class="row">
                        <!--  LEFT COLUMN: Profile Info & Subscription  -->
                        <div class="col-lg-4 mb-4">
                            <!--  Avatar Card  -->
                            <div class="p-4 rounded-3 text-center mb-4"
                                 style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(196, 154, 46, 0.13);">
                                <div class="profile-pic-wrapper mx-auto position-relative mb-3"
                                     style="width: 110px; height: 110px; border-radius: 50%; border: 2px solid #c49a2e; background: #8B0000; cursor: pointer;"
                                     onclick="document.getElementById('profile_picture').click()">
                                    <!--  Image Tag safely utilizing Odoo's image_data_uri helper  -->
                                    <t t-set="avatar_src"
                                       t-value="image_data_uri(partner.image_1920) if partner.image_1920 else ''"/>
                                    <img id="profile_img_preview" t-att-src="avatar_src"
                                         t-attf-class="w-100 h-100 rounded-circle #{'' if partner.image_1920 else 'd-none'}"
                                         style="object-fit: cover;"/>
                                    <!--  Initials (Shown only when no image exists)  -->
                                    <div t-if="not partner.image_1920" id="profile_initials"
                                         class="w-100 h-100 d-flex align-items-center justify-content-center text-white"
                                         style="font-size: 2.8rem; font-weight: bold;">
                                        <t t-esc="partner.name[0].upper() if partner.name else 'U'"/>
                                    </div>
                                    <!--  Camera Badge  -->
                                    <div class="position-absolute d-flex align-items-center justify-content-center shadow"
                                         style="bottom: 0; right: 0; width: 30px; height: 30px; background: #c49a2e; border-radius: 50%; border: 2px solid #0b110c;">
                                        <i class="fa fa-camera text-dark" style="font-size: 0.8rem;"/>
                                    </div>
                                </div>
                                <h4 class="text-white mb-1" style="font-size: 1.2rem; font-weight: 500;">
                                    <t t-esc="partner.name"/>
                                </h4>

                                <p >
                                    <t t-if="partner.is_verified">
                                            <span class="verified-badge-inline-wrapper text-yellow" style="color: #c49a2e;">
                                                <img src="/subscription_package_extended/static/src/img/verified_user_badge.png"
                                                                 alt="Verified"
                                                                 style="width: 31px; height: 31px; object-fit: contain; display: block; "/>


                                                Verified User
                                            </span>
                                        </t>
                                </p>

                                <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; margin-bottom: 1.2rem;">
                                    <t t-esc="partner.email"/>
                                </p>
                                <div class="d-inline-block px-3 py-1 rounded-pill"
                                     style="border: 1px solid #c49a2e; color: #c49a2e; font-size: 0.7rem; font-weight: bold; text-transform: uppercase;">
                                    <t t-esc="partner.subscription_plan_id.name if partner.subscription_plan_id else 'NO PLAN'"/>
                                    PLAN
                                </div>
                            </div>
                            <!--  Subscription Info Card  -->
                            <div class="p-4 rounded-3"
                                 style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(196, 154, 46, 0.13);">
                                <h5 style="color: #6b7a5e; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1.5rem; font-weight: 700;">
                                    SUBSCRIPTION
                                </h5>
                                <div class="d-flex justify-content-between mb-3" style="font-size: 0.9rem;">
                                    <span style="color: rgba(255,255,255,0.5);">Plan</span>
                                    <span style="color: #c49a2e; font-weight: 500;">
                                        <t t-esc="partner.subscription_plan_id.name if partner.subscription_plan_id else 'None'"/>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between mb-3" style="font-size: 0.9rem;">
                                    <span style="color: rgba(255,255,255,0.5);">Status</span>
                                    <span style="color: #fff;">
                                        <t t-esc="'Active' if partner.subscription_plan_id else 'Inactive'"/>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between mb-3" style="font-size: 0.9rem;">
                                    <span style="color: rgba(255,255,255,0.5);">Renews</span>
                                    <span style="color: #fff;">N/A</span>
                                </div>
                                <div class="d-flex justify-content-between mb-4" style="font-size: 0.9rem;">
                                    <span style="color: rgba(255,255,255,0.5);">Chats</span>
                                    <span style="color: #fff;">
                                        <t t-esc="partner.chat_used"/>
                                        /
                                        <t t-esc="partner.subscription_plan_id.chat_limit if partner.subscription_plan_id else 0"/>
                                    </span>
                                </div>
                                <div class="text-center mt-4">
                                    <a href="/#pricing"
                                       style="color: #c49a2e; font-size: 0.85rem; text-decoration: none; font-weight: 500;">
                                        Manage plan →
                                    </a>
                                </div>
                            </div>
                        </div>
                        <!--  RIGHT COLUMN: Form  -->
                        <div class="col-lg-8">
                            <form action="/user/profile" method="post" enctype="multipart/form-data"
                                  class="cf p-4 rounded-3"
                                  style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(196, 154, 46, 0.13);">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <!--  Hidden input for JS to access  -->
                                <input type="file" id="profile_picture" name="profile_picture" accept="image/*"
                                       class="d-none"
                                       onchange="var img = document.getElementById('profile_img_preview'); var initials = document.getElementById('profile_initials'); img.src = window.URL.createObjectURL(this.files[0]); img.classList.remove('d-none'); if(initials) { initials.classList.add('d-none'); }"/>
                                <h5 style="color: #6b7a5e; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2rem; font-weight: 700;">
                                    PERSONAL INFORMATION
                                </h5>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        FULL NAME
                                    </label>
                                    <input type="text" name="name" t-att-value="partner.name" required="1" class="w-100"
                                           style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                    <div style="color: #6b7a5e; font-size: 0.75rem; margin-top: 0.4rem;">This is your
                                        public display name.
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        EMAIL ADDRESS
                                    </label>
                                    <input type="email" name="email" t-att-value="partner.email" required="1"
                                           class="w-100"
                                           style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                </div>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        GENDER
                                    </label>
                                    <input type="text"
                                           t-att-value="partner.gender.capitalize() if partner.gender else 'Not Set'"
                                           readonly="readonly" class="w-100"
                                           style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); padding: 0.85rem 1rem; border-radius: 4px; cursor: not-allowed; outline: none;"/>
                                    <div style="color: #6b7a5e; font-size: 0.75rem; margin-top: 0.4rem;">Gender cannot
                                        be changed after registration.
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        PHONE NUMBER
                                    </label>
                                    <input type="text" name="phone" t-att-value="partner.phone" class="w-100"
                                           style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                </div>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        ADDRESS
                                    </label>
                                    <div class="row g-2 mb-2">
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <input type="text" name="street" t-att-value="partner.street"
                                                   placeholder="Street Address" class="w-100"
                                                   style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                        </div>
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <input type="text" name="street2" t-att-value="partner.street2"
                                                   placeholder="Apt, Suite, Unit (Optional)" class="w-100"
                                                   style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                        </div>
                                    </div>
                                    <div class="row g-2 mb-2">
                                        <div class="col-md-5 mb-3 mb-md-0">
                                            <input type="text" name="city" t-att-value="partner.city" placeholder="City"
                                                   class="w-100"
                                                   style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                        </div>
                                        <div class="col-md-3 mb-3 mb-md-0">
                                            <input type="text" name="zip" t-att-value="partner.zip"
                                                   placeholder="Zip Code" class="w-100"
                                                   style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none;"/>
                                        </div>
                                        <div class="col-md-4 mb-3 mb-md-0">
                                            <select name="country_id" class="w-100"
                                                    style="background: rgba(0,0,0,0.2); border: 1px solid rgba(196, 154, 46, 0.15); color: #fff; padding: 0.85rem 1rem; border-radius: 4px; outline: none; cursor: pointer;">
                                                <option value="" style="color: #888;">Select Country</option>
                                                <t t-foreach="countries" t-as="c">
                                                    <option t-att-value="c.id"
                                                            t-att-selected="c.id == partner.country_id.id"
                                                            style="color: #000;">
                                                        <t t-esc="c.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                    <div style="color: #6b7a5e; font-size: 0.75rem; margin-top: 0.4rem;">Used for
                                        membership verification purposes only.
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label style="color: rgba(255,255,255,0.4); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; font-weight: 600;">
                                        CURRENT PLAN
                                    </label>
                                    <input type="text"
                                           t-att-value="partner.subscription_plan_id.name if partner.subscription_plan_id else 'No Active Subscription'"
                                           readonly="readonly" class="w-100"
                                           style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); padding: 0.85rem 1rem; border-radius: 4px; cursor: not-allowed; outline: none;"/>
                                </div>
                                <div class="text-end mt-4">
                                    <button type="submit" class="btn btn-gold text-dark"
                                            style="font-weight: 600; font-size: 0.85rem; padding: 12px 35px; border-radius: 4px; border: none;">
                                        SAVE CHANGES
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>