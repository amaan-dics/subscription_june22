<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_agora" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.agora</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Agora Call Settings" string="Agora Video Integration"
                     name="subscription_call_integration">
                    <block title="Agora.io API Keys" name="agora_credentials_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box" id="agora_config">
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Gateway Configurations</span>
                                    <div class="text-muted">
                                        Input your project credentials to enable dynamic, secure RTC token generation.
                                    </div>
                                    <div class="content-group mt16">
                                        <div class="row">
                                            <label for="agora_app_id" class="col-lg-4 o_light_label"/>
                                            <field name="agora_app_id" placeholder="e.g. 4e88c76eb1864..."
                                                   class="w-100"/>
                                        </div>
                                        <div class="row mt8">
                                            <label for="agora_app_certificate" class="col-lg-4 o_light_label"/>
                                            <field name="agora_app_certificate" password="True"
                                                   placeholder="e.g. 90b01bf7..." class="w-100"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>