<odoo>
    <template id="request_template" name="My Requests">
        <t t-call="website.layout">
            <section class="match-page">
                <div class="match-wrap">
                    <!--  Header  -->
                    <div class="match-head">
                        <div>
                            <div class="match-eyebrow">INCOMING CONNECTIONS</div>
                            <h1>My Requests</h1>
                        </div>
                    </div>
                    <t t-if="requests">
                        <div class="req-list">
                            <t t-foreach="requests" t-as="req">
                                <div class="req-item">
                                    <div class="req-user">
                                        <img t-att-src="'/web/image/res.partner/%s/image_1920' % req.from_user_id.id"
                                             class="req-avatar"/>

                                        <div class="req-info">
                                            <div class="req-name">
                                                <t t-esc="req.from_user_id.name"/>
                                            </div>

                                            <div class="req-meta" t-if="req.from_user_id.age">
                                                <t t-esc="req.from_user_id.age"/>
                                                Years
                                            </div>

                                            <div class="req-text">
                                                Wants to connect with you.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="req-buttons">
                                        <t t-if="connection_limit_reached">
                                            <a class="req-accept req-accept--disabled"
                                               style="pointer-events:none; opacity:0.45; cursor:not-allowed;">
                                                Limit Reached
                                            </a>
                                        </t>
                                        <t t-else="">
                                            <a t-att-href="'/accept_request/%s' % req.id"
                                               class="req-accept">
                                                Accept
                                            </a>
                                        </t>

                                        <a t-att-href="'/reject_request/%s' % req.id"
                                           class="req-decline">
                                            Decline
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="req-empty">

                            <div class="req-empty-title">No Pending Requests</div>
                            <div class="req-empty-sub">When members send you connection requests, they will appear
                                here.
                            </div>
                        </div>
                    </t>
                </div>
            </section>
        </t>
    </template>
    <record id="menu_my_requests" model="website.menu">
        <field name="name">Requests</field>
        <field name="url">/my_requests</field>
        <field name="parent_id" ref="website.main_menu"/>
    </record>
    <template id="chat_template" name="Chat Page">
        <t t-call="website.layout">
            <div class="container mt-4">
                <input type="hidden" id="target_user_id" t-att-value="target_user.id"/>
                <h4 class="mb-3">
                    Chat with
                    <t t-esc="target_user.name"/>
                </h4>
                <div id="chat-box"
                     style="height:400px; border:1px solid #ddd; overflow:auto; padding:10px; background:#f9f9f9; border-radius:8px;"></div>
                <div class="mt-3 d-flex gap-2">
                    <input type="text" id="msg_input" class="form-control" placeholder="Type message..."/>
                    <button id="send_btn" class="btn btn-primary">Send</button>
                </div>
            </div>
            <script src="/subscription_package_extended/static/src/js/chat.js"/>
        </t>
    </template>
</odoo>