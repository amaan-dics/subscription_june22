<odoo>
    <template id="request_template" name="My Requests">
        <t t-call="website.layout">
            <section class="match-page">
                <div class="match-wrap">

                    <div class="match-head">
                        <div>
                            <div class="match-eyebrow">INCOMING CONNECTIONS</div>
                            <h1>Pending Requests</h1>
                        </div>
                    </div>
                    <t t-if="incoming_requests">
                        <div class="req-list mb-5">
                            <t t-foreach="incoming_requests" t-as="req">
                                <div class="req-item">
                                    <div class="req-user">
                                        <t t-if="req.from_user_id.image_1920">

                                            <img t-att-src="'/partner/avatar/%s/image_128' % req.from_user_id.id"

                                                 class="req-avatar"/>

                                        </t>

                                        <t t-else="">

                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 fill="currentColor" class="bi bi-person req-avatar"
                                                 viewBox="0 0 16 16">

                                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>

                                            </svg>

                                        </t>

                                        <div class="req-info">
                                            <div class="req-name">
                                                <t t-esc="req.from_user_id.name"/>
                                                <t t-if="p.is_verified">
                                                    <span class="verified-badge-inline-wrapper"
                                                          title="This user has been verified">
                                                        <img src="/subscription_package_extended/static/src/img/verified_user_badge.png"
                                                             alt="Verified"
                                                             style="width: 22px; height: 22px; object-fit: contain; display: block;"/>
                                                    </span>
                                                </t>
                                            </div>
                                            <div class="req-meta" t-if="req.from_user_id.age">
                                                <t t-esc="req.from_user_id.age"/>
                                                Years
                                            </div>
                                            <div class="req-text">
                                                Wants to connect with you.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="req-buttons">
                                        <t t-if="connection_limit_reached">
                                            <a class="req-accept req-accept--disabled"
                                               style="pointer-events:none; opacity:0.4; cursor:not-allowed;">
                                                Limit Reached
                                            </a>
                                        </t>
                                        <t t-else="">
                                            <a t-att-href="'/accept_request/%s' % req.id" class="req-accept">
                                                Accept
                                            </a>
                                        </t>
                                        <a t-att-href="'/reject_request/%s' % req.id" class="req-decline">
                                            Decline
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="req-empty mb-5"
                             style="padding: 30px 20px; border: 1px dashed rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.02); text-align: center; border-radius: 8px;">
                            <div class="req-empty-title"
                                 style="font-weight: 500; color: rgba(255, 255, 255, 0.5); font-size: 0.95rem; letter-spacing: 0.5px;">
                                No Pending Received Requests
                            </div>
                        </div>
                    </t>

                    <div class="match-head mt-5">
                        <div>
                            <div class="match-eyebrow">OUTGOING CONNECTIONS</div>
                            <h1>Sent Requests</h1>
                        </div>
                    </div>
                    <t t-if="sent_requests">
                        <div class="req-list mb-5">
                            <t t-foreach="sent_requests" t-as="req">
                                <div class="req-item">
                                    <div class="req-user">
                                        <t t-if="req.to_user_id.image_128">
                                            <img t-att-src="'/partner/avatar/%s/image_128' % req.to_user_id.id"
                                                 class="req-avatar"/>
                                        </t>
                                        <t t-else="">
                                            <img src="data:image/svg+xml;utf8,&lt;svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23a0aec0'&gt;&lt;path d='M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z'/&gt;&lt;/svg&gt;"
                                                 class="req-avatar"
                                                 style="background-color: #edf2f7; padding: 6px; object-fit: contain; display: block;"/>
                                        </t>

                                        <div class="req-info">
                                            <div class="req-name">
                                                <t t-esc="req.to_user_id.name"/>
                                                <t t-if="req.to_user_id.is_verified">
                                                    <span class="verified-badge-inline-wrapper mx-0"
                                                          title="This user has been verified">
                                                        <span class="verified-badge-inline-wrapper">
                                                            <img src="/subscription_package_extended/static/src/img/verified_user_badge.png"
                                                                 alt="Verified"
                                                                 style="width: 25px; height: 25px; object-fit: contain; display: block;"/>
                                                        </span>
                                                    </span>
                                                </t>
                                            </div>
                                            <div class="req-meta" t-if="req.to_user_id.age">
                                                <t t-esc="req.to_user_id.age"/>
                                                Years
                                            </div>
                                            <div class="req-text">
                                                Waiting for their response.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="req-buttons">
                                        <a t-att-href="'/cancel_request/%s' % req.id" class="req-decline">
                                            Cancel Request
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="req-empty mb-5"
                             style="padding: 30px 20px; border: 1px dashed rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.02); text-align: center; border-radius: 8px;">
                            <div class="req-empty-title"
                                 style="font-weight: 500; color: rgba(255, 255, 255, 0.5); font-size: 0.95rem; letter-spacing: 0.5px;">
                                No Pending Sent Requests
                            </div>
                        </div>
                    </t>

                    <div class="match-head mt-5">
                        <div>
                            <div class="match-eyebrow">YOUR MATCHES</div>
                            <h1>Connected Members</h1>
                        </div>
                    </div>
                    <t t-if="accepted_requests">
                        <div class="req-list">
                            <t t-foreach="accepted_requests" t-as="req">
                                <div class="req-item">
                                    <div class="req-user">
                                        <img t-att-src="'/partner/avatar/%s/image_128' % req.to_user_id.id"
                                             class="req-avatar"/>

                                        <div class="req-info">
                                            <div class="req-name">
                                                <t t-esc="req.to_user_id.name"/>
                                                <t t-if="req.to_user_id.is_verified">
                                                    <span class="verified-badge-inline-wrapper mx-0"
                                                          title="This user has been verified">
                                                        <span class="verified-badge-inline-wrapper">
                                                            <img src="/subscription_package_extended/static/src/img/verified_user_badge.png"
                                                                 alt="Verified"
                                                                 style="width: 25px; height: 25px; object-fit: contain; display: block;"/>
                                                        </span>
                                                    </span>
                                                </t>
                                            </div>
                                            <div class="req-meta" t-if="req.to_user_id.age">
                                                <t t-esc="req.to_user_id.age"/>
                                                Years
                                            </div>
                                            <div class="req-text" style="color: #10b981; font-weight: 500;">
                                                You are connected!
                                            </div>
                                        </div>
                                    </div>

                                    <div class="req-buttons">
                                        <a t-att-href="'/chatbox?user_id=%s' % req.to_user_id.id" class="req-accept">
                                            Chat Now
                                        </a>
                                        <a t-att-href="'/unmatch_request/%s' % req.id" class="req-decline"
                                           t-attf-onclick="return confirm('Are you sure you want to unmatch #{req.to_user_id.name}? This will remove them from your messages.');">
                                            Unmatch
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="req-empty"
                             style="padding: 30px 20px; border: 1px dashed rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.02); text-align: center; border-radius: 8px;">
                            <div class="req-empty-title"
                                 style="font-weight: 500; color: rgba(255, 255, 255, 0.5); font-size: 0.95rem; letter-spacing: 0.5px;">
                                No Connected Members Yet
                            </div>
                        </div>
                    </t>

                </div>
            </section>
        </t>
    </template>

    <record id="menu_my_requests" model="website.menu">
        <field name="name">Requests</field>
        <field name="url">/my_requests</field>
        <field name="parent_id" ref="website.main_menu"/>
    </record>

    <template id="chat_template" name="Chat Page">
        <t t-call="website.layout">
            <div class="container mt-4">
                <input type="hidden" id="target_user_id" t-att-value="target_user.id"/>
                <h4 class="mb-3">
                    Chat with
                    <t t-esc="target_user.name"/>
                </h4>
                <div id="chat-box"
                     style="height:400px; border:1px solid #ddd; overflow:auto; padding:10px; background:#f9f9f9; border-radius:8px;"></div>
                <div class="mt-3 d-flex gap-2">
                    <input type="text" id="msg_input" class="form-control" placeholder="Type message..."/>
                    <button id="send_btn" class="btn btn-primary">Send</button>
                </div>
            </div>
            <script src="/subscription_package_extended/static/src/js/chat.js"/>
        </t>
    </template>
</odoo>