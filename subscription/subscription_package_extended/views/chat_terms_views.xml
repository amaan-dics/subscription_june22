<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_chat_terms_tree" model="ir.ui.view">
        <field name="name">chat.terms.tree</field>
        <field name="model">chat.terms</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_chat_terms_form" model="ir.ui.view">
        <field name="name">chat.terms.form</field>
        <field name="model">chat.terms</field>
        <field name="arch" type="xml">
            <form string="Chat Terms">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>

                    <group>
                        <field name="content" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chat_terms" model="ir.actions.act_window">
        <field name="name">Chat Terms</field>
        <field name="res_model">chat.terms</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_chat_terms"
              name="Terms &amp; Conditions"
              parent="subscription_package.subscription_menu_config"
              action="action_chat_terms"
              sequence="40"/>

</odoo>