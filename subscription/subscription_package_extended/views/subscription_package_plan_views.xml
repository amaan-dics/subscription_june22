<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_subscription_plan_form_inherit_type" model="ir.ui.view">
        <field name="name">subscription.package.plan.form.inherit.type</field>
        <field name="model">subscription.package.plan</field>
        <field name="inherit_id" ref="subscription_package.subscription_plan_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='limit_choice']" position="before">
                <label for="subscription_type_id"/>
                <div class="o_row">
                    <field name="subscription_type_id" required="True"/>
                    <field name="price" required="True"/>
                </div>
                <field name="connection_limit"/>
                <field name="chat_limit"/>
                <field name="product_id"/>

            </xpath>

            <xpath expr="//group" position="after">
                <group string="Plan Details">
                    <field name="description"/>
                </group>
                <group string="Features">
                    <field name="feature_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="is_available"/>
                        </list>
                    </field>
                </group>
            </xpath>

        </field>
    </record>

</odoo>