<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_res_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_kyc_approved" type="object" string="KYC Approve" class="oe_highlight"/>
                    <button name="action_kyc_rejected" type="object" string="KYC Rejected" class="oe_highlight"/>
                </header>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="Other Info">
                    <group>
                        <group>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="selfie" widget="image"/>
                            <field name="selfie_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="subscription_plan_id"/>
                            <field name="kyc_status"/>
                            <field name="id_proof" widget="image"/>
                            <field name="id_proof_filename" invisible="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>