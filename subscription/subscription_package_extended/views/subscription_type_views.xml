<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_subscription_type_tree" model="ir.ui.view">
        <field name="name">subscription.type.tree</field>
        <field name="model">subscription.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="connection_limit"/>
                <field name="chat_limit"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="view_subscription_type_form" model="ir.ui.view">
        <field name="name">subscription.type.form</field>
        <field name="model">subscription.type</field>
        <field name="arch" type="xml">
            <form string="Subscription Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                        </group>
                        <group>
                            <field name="connection_limit"/>
                            <field name="chat_limit"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_subscription_type" model="ir.actions.act_window">
        <field name="name">Subscription Types</field>
        <field name="res_model">subscription.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_subscription_type"
              name="Subscription Type"
              parent="subscription_package.subscription_menu_config"
              action="action_subscription_type"
              sequence="30"
              groups="subscription_package.group_subscription_manager"/>

</odoo>